<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Mattéo_Hubert_App.MainPage"
             Title="Accueil">

    <ScrollView>
        <VerticalStackLayout
            Padding="30,0"
            Spacing="25">
            <Image
                Source="rakai_reading.png"
                HeightRequest="185"
                Aspect="AspectFit"
                SemanticProperties.Description="Rakai is reading a book for the first time of his life" />

            <Label
                Text="Bonjour la team"
                Style="{StaticResource Headline}"
                SemanticProperties.HeadingLevel="Level1" />

            <Label
                Text="Bienvenue&#10;"
                Style="{StaticResource SubHeadline}"
                SemanticProperties.HeadingLevel="Level2"
                SemanticProperties.Description="Bienvenue sur notre première appli MAUI" />
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
